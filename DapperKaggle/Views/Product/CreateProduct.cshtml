@model DapperKaggle.Dtos.ProductDtos.CreateProductDto

@{
    ViewData["Title"] = "CreateProduct";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}



<div class="pd-20 card-box mb-30">
    <h4 class="text-blue h4">Create Product</h4>

    <form method="post" asp-controller="Product" asp-action="CreateProduct">

       

        <div class="form-group">
            <label>Product Name</label>
            <input asp-for="ProductName" class="form-control">
        </div>

        <div class="form-group">
            <label>Category</label>
            <input asp-for="Category" class="form-control">
        </div>

        <div class="form-group">
            <label>Sub Category</label>
            <input asp-for="SubCategory" class="form-control">
        </div>

        <div class="form-group">
            <label>Brand</label>
            <input asp-for="Brand" class="form-control">
        </div>

        <div class="form-group">
            <label>Unit Price</label>
            <input asp-for="UnitPrice" class="form-control">
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>