@model DapperKaggle.Models.ProductListViewModel
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}



<div class="pd-20 card-box mb-30">
    <div class="clearfix">
        <div class="pull-left">
            <h4 class="text-blue h4">Products</h4>
            <p>Product CRUD, search, filter and pagination.</p>
        </div>
        <div class="pull-right">
            <a asp-controller="Product" asp-action="CreateProduct" class="btn btn-primary">
                Add New Product
            </a>
        </div>
    </div>

    <form method="get" asp-controller="Product" asp-action="Index" class="mt-3">
        <div class="row">
            <div class="col-md-4">
                <label>Search</label>
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Product name">
            </div>

            <div class="col-md-3">
                <label>Category</label>
                <select name="category" class="form-control">
                    <option value="">All Categories</option>
                    @foreach (var item in Model.Categories)
                    {
                        <option value="@item" selected="@(Model.Category == item)">
                            @item
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label>Brand</label>
                <select name="brand" class="form-control">
                    <option value="">All Brands</option>
                    @foreach (var item in Model.Brands)
                    {
                        <option value="@item" selected="@(Model.Brand == item)">
                            @item
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label>&nbsp;</label>
                <button class="btn btn-primary btn-block">Filter</button>
            </div>
        </div>
    </form>
</div>

<div class="card-box mb-30">
    <div class="pd-20">
        <h4 class="text-blue h4">Product List</h4>
        <p>Total Records: @Model.TotalCount.ToString("N0")</p>
    </div>

    <div class="table-responsive">
        <table class="table hover nowrap">
            <thead>
                <tr>
                    <th>Product Id</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Sub Category</th>
                    <th>Brand</th>
                    <th>Unit Price</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>@item.ProductId</td>
                        <td>@item.ProductName</td>
                        <td>@item.Category</td>
                        <td>@item.SubCategory</td>
                        <td>@item.Brand</td>
                        <td>$@item.UnitPrice.ToString("N2")</td>
                        <td>
                            <a asp-controller="Product"
                               asp-action="UpdateProduct"
                               asp-route-id="@item.ProductId"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-controller="Product"
                               asp-action="DeleteProduct"
                               asp-route-id="@item.ProductId"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this product?')">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pd-20">
            <nav>
                <ul class="pagination">

                    @if (Model.Page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-route-page="@(Model.Page - 1)"
                               asp-route-search="@Model.Search"
                               asp-route-category="@Model.Category"
                               asp-route-brand="@Model.Brand">
                                Previous
                            </a>
                        </li>
                    }

                    @{
                        int startPage = Math.Max(1, Model.Page - 3);
                        int endPage = Math.Min(Model.TotalPages, Model.Page + 3);
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(Model.Page == i ? "active" : "")">
                            <a class="page-link"
                               asp-route-page="@i"
                               asp-route-search="@Model.Search"
                               asp-route-category="@Model.Category"
                               asp-route-brand="@Model.Brand">
                                @i
                            </a>
                        </li>
                    }

                    @if (Model.Page < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-route-page="@(Model.Page + 1)"
                               asp-route-search="@Model.Search"
                               asp-route-category="@Model.Category"
                               asp-route-brand="@Model.Brand">
                                Next
                            </a>
                        </li>
                    }

                </ul>
            </nav>
        </div>
    }
</div>